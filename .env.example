# OpenAI API Key for embeddings (REQUIRED)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Template configuration file path (OPTIONAL)
# Default: config/template.yaml
# Set to a private template file if you keep templates out of the repo
# TEMPLATE_CONFIG=config/template.yaml

# TimescaleDB connection for semantic memory (OPTIONAL)
# If not set, semantic memory features will be unavailable
# Get from: https://console.timescale.cloud
MEMORY_DB_URL=postgresql://user:password@host:port/database?sslmode=require
HERMES_APP_PASSWORD=hermes_app_password

# OpenAI embedding model to use (OPTIONAL)
# Default: text-embedding-3-small
# Options: text-embedding-3-small (1536), text-embedding-3-large (3072), text-embedding-ada-002 (1536)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI embedding dimensions (OPTIONAL)
# Must match the model: text-embedding-3-small=1536, text-embedding-3-large=3072
# Default: 1536 (auto-detected from model)
# OPENAI_EMBEDDING_DIM=1536

# LangMem auto-memory extraction (OPTIONAL)
# Enabled by default when semantic memory is configured
# Set false to disable automatic memory writing
# LANGMEM_ENABLED=true

# LangMem extraction model (OPTIONAL)
# Default provider/model: ollama + current chat model
# LANGMEM_MODEL_PROVIDER=ollama
# LANGMEM_MODEL=hf.co/DevQuasar/NousResearch.Hermes-4-14B-GGUF:Q8_0
# LANGMEM_TEMPERATURE=0.2
# LANGMEM_MAX_MEMORIES_PER_TURN=2
# LANGMEM_DEFAULT_TAG=chat
